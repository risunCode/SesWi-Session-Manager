{
  "name": "seswi-session-manager",
  "version": "4.0.2",
  "description": "Chrome/Firefox extension for managing cookies, login sessions, and 2FA TOTP vaults with encrypted backup, quick restore, tab cleanup, and master-password protection",
  "type": "module",
  "scripts": {
    "dev": "wxt dev",
    "dev:firefox": "wxt dev -b firefox --mv3",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "chrome-extension",
    "session-manager",
    "cookies",
    "2fa",
    "totp",
    "password-manager",
    "privacy"
  ],
  "author": "risunCode",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/test-utils": "^2.4.11",
    "@wxt-dev/module-vue": "^1.0.3",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.2.6",
    "vitest": "^3.2.4",
    "vue": "^3.5.39",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@noble/hashes": "^2.2.0",
    "jsqr": "^1.4.0"
  }
}
